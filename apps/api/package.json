{
  "name": "@qdd/api",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "dev": "pnpm --filter @qdd/shared build && pnpm prisma:generate && tsx watch src/main.ts",
    "start": "node dist/main.js",
    "worker:dev": "pnpm --filter @qdd/shared build && tsx watch src/worker.ts",
    "worker:start": "node dist/worker.js",
    "build": "pnpm prisma:generate && tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "pnpm prisma:generate && vitest run",
    "test:unit": "pnpm prisma:generate && vitest run",
    "test:integration": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --check .",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "db:migrate": "prisma migrate deploy --config prisma.config.ts",
    "db:seed": "pnpm prisma:generate && tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "11.1.24",
    "@nestjs/core": "11.1.24",
    "@nestjs/platform-express": "11.1.24",
    "@nestjs/swagger": "11.4.4",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@qdd/shared": "workspace:*",
    "argon2": "0.44.0",
    "cookie": "1.1.1",
    "dotenv": "17.4.2",
    "helmet": "8.2.0",
    "pg": "8.21.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.24",
    "@types/express": "5.0.6",
    "@types/node": "24.12.4",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.0",
    "prisma": "7.8.0",
    "supertest": "7.2.2",
    "tsx": "4.22.3",
    "vitest": "4.1.7"
  }
}
